{
  "name": "md-index-explorer",
  "displayName": "Markdown Index",
  "description": "A lightweight Table of Contents for markdown files, displayed in the Explorer panel.",
  "version": "0.6.1",
  "publisher": "felipedecastro",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FelipeDeCastro/markdown-index"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "table of contents",
    "toc",
    "outline",
    "index",
    "headings"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownIndexSidebar",
          "title": "Markdown Index",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "markdownIndex",
          "name": "Markdown Index",
          "contextualTitle": "Markdown Index",
          "when": "config.markdownIndex.location == 'explorer'"
        }
      ],
      "markdownIndexSidebar": [
        {
          "id": "markdownIndexSidebarView",
          "name": "Markdown Index",
          "contextualTitle": "Markdown Index"
        }
      ]
    },
    "commands": [
      {
        "command": "markdownIndex.revealHeading",
        "title": "Go to Heading",
        "category": "Markdown Index"
      },
      {
        "command": "markdownIndex.revealInEditor",
        "title": "Reveal in Editor",
        "category": "Markdown Index",
        "icon": "$(go-to-file)"
      },
      {
        "command": "markdownIndex.revealInPreview",
        "title": "Reveal in Preview",
        "category": "Markdown Index",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdownIndex.refresh",
        "title": "Refresh",
        "category": "Markdown Index",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownIndex.collapseAll",
        "title": "Collapse All",
        "category": "Markdown Index",
        "icon": "$(collapse-all)"
      },
      {
        "command": "markdownIndex.expandAll",
        "title": "Expand All",
        "category": "Markdown Index",
        "icon": "$(expand-all)"
      },
      {
        "command": "markdownIndex.search",
        "title": "Search Headings",
        "category": "Markdown Index",
        "icon": "$(search)"
      },
      {
        "command": "markdownIndex.clearSearch",
        "title": "Clear Search",
        "category": "Markdown Index",
        "icon": "$(search-stop)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "markdownIndex.collapseAll",
          "when": "(view == markdownIndex || view == markdownIndexSidebarView) && !markdownIndex.allCollapsed",
          "group": "navigation"
        },
        {
          "command": "markdownIndex.expandAll",
          "when": "(view == markdownIndex || view == markdownIndexSidebarView) && markdownIndex.allCollapsed",
          "group": "navigation"
        },
        {
          "command": "markdownIndex.search",
          "when": "view == markdownIndex || view == markdownIndexSidebarView",
          "group": "navigation"
        },
        {
          "command": "markdownIndex.clearSearch",
          "when": "(view == markdownIndex || view == markdownIndexSidebarView) && markdownIndex.isFiltered",
          "group": "navigation"
        },
        {
          "command": "markdownIndex.refresh",
          "when": "view == markdownIndex || view == markdownIndexSidebarView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "markdownIndex.revealInPreview",
          "when": "(view == markdownIndex || view == markdownIndexSidebarView) && viewItem == heading && config.markdownIndex.clickAction != 'preview'",
          "group": "inline"
        },
        {
          "command": "markdownIndex.revealInEditor",
          "when": "(view == markdownIndex || view == markdownIndexSidebarView) && viewItem == heading && config.markdownIndex.clickAction == 'preview'",
          "group": "inline"
        },
        {
          "command": "markdownIndex.revealInEditor",
          "when": "view == markdownIndex || view == markdownIndexSidebarView",
          "group": "navigation@1"
        },
        {
          "command": "markdownIndex.revealInPreview",
          "when": "view == markdownIndex || view == markdownIndexSidebarView",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Index",
      "properties": {
        "markdownIndex.clickAction": {
          "type": "string",
          "enum": [
            "editor",
            "preview"
          ],
          "default": "preview",
          "description": "Where to navigate when clicking a heading: open in the editor or in the markdown preview."
        },
        "markdownIndex.location": {
          "type": "string",
          "enum": [
            "explorer",
            "sidebar"
          ],
          "enumDescriptions": [
            "Show inside the Explorer panel",
            "Show as its own icon in the sidebar"
          ],
          "default": "sidebar",
          "description": "Where to display the Markdown Index view."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
