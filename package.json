{
  "name": "markdown-index",
  "displayName": "Markdown Index",
  "description": "A lightweight Table of Contents for markdown files, displayed in the Explorer panel.",
  "version": "0.1.0",
  "publisher": "felipedecastro",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FelipeDeCastro/markdown-index"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "table of contents",
    "toc",
    "outline",
    "index",
    "headings"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "markdownIndex",
          "name": "Markdown Index",
          "icon": "$(list-tree)",
          "contextualTitle": "Markdown Index"
        }
      ]
    },
    "commands": [
      {
        "command": "markdownIndex.revealHeading",
        "title": "Go to Heading",
        "category": "Markdown Index"
      },
      {
        "command": "markdownIndex.revealInEditor",
        "title": "Reveal in Editor",
        "category": "Markdown Index",
        "icon": "$(go-to-file)"
      },
      {
        "command": "markdownIndex.revealInPreview",
        "title": "Reveal in Preview",
        "category": "Markdown Index",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdownIndex.refresh",
        "title": "Refresh",
        "category": "Markdown Index",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "markdownIndex.refresh",
          "when": "view == markdownIndex",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "markdownIndex.revealInPreview",
          "when": "view == markdownIndex && viewItem == heading",
          "group": "inline"
        },
        {
          "command": "markdownIndex.revealInEditor",
          "when": "view == markdownIndex",
          "group": "navigation@1"
        },
        {
          "command": "markdownIndex.revealInPreview",
          "when": "view == markdownIndex",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Index",
      "properties": {
        "markdownIndex.clickAction": {
          "type": "string",
          "enum": ["editor", "preview"],
          "default": "editor",
          "description": "Where to navigate when clicking a heading: open in the editor or in the markdown preview."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
